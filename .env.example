# ─────────────────────────────────────────────────────────────────
# BatchLens environment variables
# Copy this file to .env and set values for local development.
# In Vercel: set these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────

# Phase 1 / 2 (Public Beta): set to "true" — all Pro features free, banner shown.
# Phase 3 (Paid Launch):     set to "false" — paywall active, banner hidden.
VITE_PUBLIC_BETA=true
